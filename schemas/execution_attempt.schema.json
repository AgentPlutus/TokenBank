{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "attempt_id": {
      "minLength": 1,
      "title": "Attempt Id",
      "type": "string"
    },
    "attempt_number": {
      "default": 1,
      "exclusiveMinimum": 0,
      "title": "Attempt Number",
      "type": "integer"
    },
    "completed_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Completed At"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "policy_decision_id": {
      "minLength": 1,
      "title": "Policy Decision Id",
      "type": "string"
    },
    "route_plan_id": {
      "minLength": 1,
      "title": "Route Plan Id",
      "type": "string"
    },
    "schema_version": {
      "const": "p0.v1",
      "default": "p0.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "started_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Started At"
    },
    "status": {
      "default": "created",
      "enum": [
        "created",
        "scheduled",
        "assigned",
        "running",
        "succeeded",
        "failed",
        "quarantined",
        "cancelled"
      ],
      "title": "Status",
      "type": "string"
    },
    "work_unit_id": {
      "minLength": 1,
      "title": "Work Unit Id",
      "type": "string"
    }
  },
  "required": [
    "attempt_id",
    "work_unit_id",
    "route_plan_id",
    "policy_decision_id"
  ],
  "title": "ExecutionAttempt",
  "type": "object"
}

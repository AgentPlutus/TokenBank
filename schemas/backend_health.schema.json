{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "backend_id": {
      "minLength": 1,
      "title": "Backend Id",
      "type": "string"
    },
    "checked_at": {
      "format": "date-time",
      "title": "Checked At",
      "type": "string"
    },
    "latency_ms": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Latency Ms"
    },
    "message": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Message"
    },
    "schema_version": {
      "const": "p0.v1",
      "default": "p0.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "status": {
      "default": "unknown",
      "enum": [
        "healthy",
        "degraded",
        "unhealthy",
        "unknown"
      ],
      "title": "Status",
      "type": "string"
    }
  },
  "required": [
    "backend_id"
  ],
  "title": "BackendHealth",
  "type": "object"
}

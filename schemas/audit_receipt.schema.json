{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Redacted audit chain from WorkUnit through VerifierReport.",
  "properties": {
    "assignment_hash": {
      "minLength": 1,
      "title": "Assignment Hash",
      "type": "string"
    },
    "assignment_id": {
      "minLength": 1,
      "title": "Assignment Id",
      "type": "string"
    },
    "audit_receipt_id": {
      "minLength": 1,
      "title": "Audit Receipt Id",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "previous_receipt_hash": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Previous Receipt Hash"
    },
    "reason_codes": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "title": "Reason Codes",
      "type": "array"
    },
    "receipt_hash": {
      "minLength": 1,
      "title": "Receipt Hash",
      "type": "string"
    },
    "redaction_profile": {
      "const": "ids_and_hashes_only",
      "default": "ids_and_hashes_only",
      "title": "Redaction Profile",
      "type": "string"
    },
    "result_envelope_hash": {
      "minLength": 1,
      "title": "Result Envelope Hash",
      "type": "string"
    },
    "result_envelope_id": {
      "minLength": 1,
      "title": "Result Envelope Id",
      "type": "string"
    },
    "result_hash": {
      "minLength": 1,
      "title": "Result Hash",
      "type": "string"
    },
    "route_plan_hash": {
      "minLength": 1,
      "title": "Route Plan Hash",
      "type": "string"
    },
    "route_plan_id": {
      "minLength": 1,
      "title": "Route Plan Id",
      "type": "string"
    },
    "routebook_id": {
      "default": "tokenbank.base",
      "minLength": 1,
      "title": "Routebook Id",
      "type": "string"
    },
    "routebook_version": {
      "default": "unknown",
      "minLength": 1,
      "title": "Routebook Version",
      "type": "string"
    },
    "run_id": {
      "minLength": 1,
      "title": "Run Id",
      "type": "string"
    },
    "schema_version": {
      "const": "p0.v1",
      "default": "p0.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "status": {
      "enum": [
        "accepted",
        "accepted_with_warning"
      ],
      "title": "Status",
      "type": "string"
    },
    "task_analysis_hash": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Task Analysis Hash"
    },
    "task_profile_hash": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Task Profile Hash"
    },
    "usage_ledger_entry_hash": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Usage Ledger Entry Hash"
    },
    "usage_ledger_entry_id": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Usage Ledger Entry Id"
    },
    "verifier_report_hash": {
      "minLength": 1,
      "title": "Verifier Report Hash",
      "type": "string"
    },
    "verifier_report_id": {
      "minLength": 1,
      "title": "Verifier Report Id",
      "type": "string"
    },
    "work_unit_hash": {
      "minLength": 1,
      "title": "Work Unit Hash",
      "type": "string"
    },
    "work_unit_id": {
      "minLength": 1,
      "title": "Work Unit Id",
      "type": "string"
    }
  },
  "required": [
    "audit_receipt_id",
    "work_unit_id",
    "run_id",
    "route_plan_id",
    "assignment_id",
    "result_envelope_id",
    "verifier_report_id",
    "status",
    "work_unit_hash",
    "route_plan_hash",
    "assignment_hash",
    "result_hash",
    "result_envelope_hash",
    "verifier_report_hash",
    "receipt_hash"
  ],
  "title": "AuditReceipt",
  "type": "object"
}

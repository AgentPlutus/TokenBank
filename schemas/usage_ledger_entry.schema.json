{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Local, redacted usage accounting for one WorkUnit result.",
  "properties": {
    "account_snapshot_id": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Account Snapshot Id"
    },
    "backend_id": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Backend Id"
    },
    "billable_cost_micros": {
      "default": 0,
      "minimum": 0,
      "title": "Billable Cost Micros",
      "type": "integer"
    },
    "capacity_node_id": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Capacity Node Id"
    },
    "capacity_profile_id": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Capacity Profile Id"
    },
    "cost_source": {
      "default": "estimated",
      "enum": [
        "estimated",
        "provider_reported",
        "manual",
        "not_applicable"
      ],
      "title": "Cost Source",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "entry_hash": {
      "minLength": 1,
      "title": "Entry Hash",
      "type": "string"
    },
    "estimated_cost_micros": {
      "default": 0,
      "minimum": 0,
      "title": "Estimated Cost Micros",
      "type": "integer"
    },
    "estimated_input_tokens": {
      "default": 0,
      "minimum": 0,
      "title": "Estimated Input Tokens",
      "type": "integer"
    },
    "estimated_output_tokens": {
      "default": 0,
      "minimum": 0,
      "title": "Estimated Output Tokens",
      "type": "integer"
    },
    "estimated_total_tokens": {
      "default": 0,
      "minimum": 0,
      "title": "Estimated Total Tokens",
      "type": "integer"
    },
    "model_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Model Id"
    },
    "provider_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Provider Id"
    },
    "reported_cost_micros": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Reported Cost Micros"
    },
    "reported_input_tokens": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Reported Input Tokens"
    },
    "reported_output_tokens": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Reported Output Tokens"
    },
    "reported_total_tokens": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Reported Total Tokens"
    },
    "result_envelope_id": {
      "minLength": 1,
      "title": "Result Envelope Id",
      "type": "string"
    },
    "route_plan_id": {
      "minLength": 1,
      "title": "Route Plan Id",
      "type": "string"
    },
    "routebook_id": {
      "default": "tokenbank.base",
      "minLength": 1,
      "title": "Routebook Id",
      "type": "string"
    },
    "routebook_version": {
      "default": "unknown",
      "minLength": 1,
      "title": "Routebook Version",
      "type": "string"
    },
    "run_id": {
      "minLength": 1,
      "title": "Run Id",
      "type": "string"
    },
    "schema_version": {
      "const": "p0.v1",
      "default": "p0.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "usage_ledger_entry_id": {
      "minLength": 1,
      "title": "Usage Ledger Entry Id",
      "type": "string"
    },
    "usage_source": {
      "default": "estimate",
      "enum": [
        "estimate",
        "provider_response",
        "manual"
      ],
      "title": "Usage Source",
      "type": "string"
    },
    "verifier_recommendation": {
      "anyOf": [
        {
          "enum": [
            "accept",
            "accept_with_warning",
            "retry",
            "fallback",
            "reject",
            "quarantine",
            "escalate",
            "review"
          ],
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Verifier Recommendation"
    },
    "verifier_report_id": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Verifier Report Id"
    },
    "work_unit_id": {
      "minLength": 1,
      "title": "Work Unit Id",
      "type": "string"
    }
  },
  "required": [
    "usage_ledger_entry_id",
    "work_unit_id",
    "run_id",
    "route_plan_id",
    "result_envelope_id",
    "entry_hash"
  ],
  "title": "UsageLedgerEntry",
  "type": "object"
}

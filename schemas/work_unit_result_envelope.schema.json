{
  "$defs": {
    "ArtifactRef": {
      "additionalProperties": false,
      "properties": {
        "artifact_hash": {
          "minLength": 1,
          "title": "Artifact Hash",
          "type": "string"
        },
        "artifact_id": {
          "minLength": 1,
          "title": "Artifact Id",
          "type": "string"
        },
        "media_type": {
          "default": "application/octet-stream",
          "minLength": 1,
          "title": "Media Type",
          "type": "string"
        },
        "metadata": {
          "additionalProperties": true,
          "title": "Metadata",
          "type": "object"
        },
        "schema_version": {
          "const": "p0.v1",
          "default": "p0.v1",
          "title": "Schema Version",
          "type": "string"
        },
        "uri": {
          "minLength": 1,
          "title": "Uri",
          "type": "string"
        }
      },
      "required": [
        "artifact_id",
        "uri",
        "artifact_hash"
      ],
      "title": "ArtifactRef",
      "type": "object"
    },
    "BackendError": {
      "additionalProperties": false,
      "properties": {
        "error_code": {
          "minLength": 1,
          "title": "Error Code",
          "type": "string"
        },
        "error_message": {
          "minLength": 1,
          "title": "Error Message",
          "type": "string"
        },
        "fallbackable": {
          "default": false,
          "title": "Fallbackable",
          "type": "boolean"
        },
        "occurred_at": {
          "format": "date-time",
          "title": "Occurred At",
          "type": "string"
        },
        "redacted_details": {
          "additionalProperties": true,
          "title": "Redacted Details",
          "type": "object"
        },
        "retryable": {
          "default": false,
          "title": "Retryable",
          "type": "boolean"
        },
        "schema_version": {
          "const": "p0.v1",
          "default": "p0.v1",
          "title": "Schema Version",
          "type": "string"
        }
      },
      "required": [
        "error_code",
        "error_message"
      ],
      "title": "BackendError",
      "type": "object"
    },
    "UsageRecord": {
      "additionalProperties": false,
      "properties": {
        "actual_cost_micros": {
          "default": 0,
          "minimum": 0,
          "title": "Actual Cost Micros",
          "type": "integer"
        },
        "attempt_id": {
          "minLength": 1,
          "title": "Attempt Id",
          "type": "string"
        },
        "backend_id": {
          "minLength": 1,
          "title": "Backend Id",
          "type": "string"
        },
        "cost_confidence": {
          "default": "not_applicable",
          "enum": [
            "low",
            "medium",
            "high",
            "not_applicable"
          ],
          "title": "Cost Confidence",
          "type": "string"
        },
        "cost_source": {
          "default": "not_applicable",
          "enum": [
            "measured",
            "estimated",
            "policy_default",
            "zero_internal_phase0",
            "not_applicable"
          ],
          "title": "Cost Source",
          "type": "string"
        },
        "estimated_cost_micros": {
          "default": 0,
          "minimum": 0,
          "title": "Estimated Cost Micros",
          "type": "integer"
        },
        "input_units": {
          "default": 0,
          "minimum": 0,
          "title": "Input Units",
          "type": "integer"
        },
        "output_units": {
          "default": 0,
          "minimum": 0,
          "title": "Output Units",
          "type": "integer"
        },
        "recorded_at": {
          "format": "date-time",
          "title": "Recorded At",
          "type": "string"
        },
        "schema_version": {
          "const": "p0.v1",
          "default": "p0.v1",
          "title": "Schema Version",
          "type": "string"
        },
        "usage_record_id": {
          "minLength": 1,
          "title": "Usage Record Id",
          "type": "string"
        },
        "work_unit_id": {
          "minLength": 1,
          "title": "Work Unit Id",
          "type": "string"
        }
      },
      "required": [
        "usage_record_id",
        "work_unit_id",
        "attempt_id",
        "backend_id"
      ],
      "title": "UsageRecord",
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "actual_cost_micros": {
      "default": 0,
      "minimum": 0,
      "title": "Actual Cost Micros",
      "type": "integer"
    },
    "artifact_refs": {
      "items": {
        "$ref": "#/$defs/ArtifactRef"
      },
      "title": "Artifact Refs",
      "type": "array"
    },
    "assignment_id": {
      "minLength": 1,
      "title": "Assignment Id",
      "type": "string"
    },
    "attempt_id": {
      "minLength": 1,
      "title": "Attempt Id",
      "type": "string"
    },
    "backend_class": {
      "anyOf": [
        {
          "enum": [
            "local_tool",
            "local_script",
            "browser_fetch",
            "local_model",
            "api_model_gateway",
            "primary_model_gateway"
          ],
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Backend Class"
    },
    "backend_error": {
      "anyOf": [
        {
          "$ref": "#/$defs/BackendError"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "backend_id": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Backend Id"
    },
    "capacity_node_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Capacity Node Id"
    },
    "completed_at": {
      "format": "date-time",
      "title": "Completed At",
      "type": "string"
    },
    "cost_confidence": {
      "default": "not_applicable",
      "enum": [
        "low",
        "medium",
        "high",
        "not_applicable"
      ],
      "title": "Cost Confidence",
      "type": "string"
    },
    "cost_estimate_micros": {
      "default": 0,
      "minimum": 0,
      "title": "Cost Estimate Micros",
      "type": "integer"
    },
    "cost_source": {
      "default": "not_applicable",
      "enum": [
        "measured",
        "estimated",
        "policy_default",
        "zero_internal_phase0",
        "not_applicable"
      ],
      "title": "Cost Source",
      "type": "string"
    },
    "duration_ms": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Duration Ms"
    },
    "errors": {
      "items": {
        "$ref": "#/$defs/BackendError"
      },
      "title": "Errors",
      "type": "array"
    },
    "model_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Model Id"
    },
    "output": {
      "additionalProperties": true,
      "title": "Output",
      "type": "object"
    },
    "output_hash": {
      "minLength": 1,
      "title": "Output Hash",
      "type": "string"
    },
    "provider_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Provider Id"
    },
    "redacted_logs": {
      "items": {
        "type": "string"
      },
      "title": "Redacted Logs",
      "type": "array"
    },
    "result_envelope_id": {
      "minLength": 1,
      "title": "Result Envelope Id",
      "type": "string"
    },
    "result_hash": {
      "minLength": 1,
      "title": "Result Hash",
      "type": "string"
    },
    "run_id": {
      "minLength": 1,
      "title": "Run Id",
      "type": "string"
    },
    "schema_version": {
      "const": "p0.v1",
      "default": "p0.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "started_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Started At"
    },
    "status": {
      "enum": [
        "succeeded",
        "failed",
        "quarantined"
      ],
      "title": "Status",
      "type": "string"
    },
    "usage_records": {
      "items": {
        "$ref": "#/$defs/UsageRecord"
      },
      "title": "Usage Records",
      "type": "array"
    },
    "work_unit_id": {
      "minLength": 1,
      "title": "Work Unit Id",
      "type": "string"
    },
    "worker_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Worker Id"
    }
  },
  "required": [
    "result_envelope_id",
    "work_unit_id",
    "run_id",
    "attempt_id",
    "assignment_id",
    "status",
    "output_hash",
    "result_hash"
  ],
  "title": "WorkUnitResultEnvelope",
  "type": "object"
}

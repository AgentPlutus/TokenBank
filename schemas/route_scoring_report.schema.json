{
  "$defs": {
    "CandidateScore": {
      "additionalProperties": false,
      "properties": {
        "capability_fit": {
          "default": 0.0,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Capability Fit",
          "type": "number"
        },
        "cost_fit": {
          "default": 0.0,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Cost Fit",
          "type": "number"
        },
        "latency_fit": {
          "default": 0.0,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Latency Fit",
          "type": "number"
        },
        "policy_fit": {
          "default": 1.0,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Policy Fit",
          "type": "number"
        },
        "quality_fit": {
          "default": 0.0,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Quality Fit",
          "type": "number"
        },
        "schema_version": {
          "const": "p0.v1",
          "default": "p0.v1",
          "title": "Schema Version",
          "type": "string"
        },
        "total": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Total",
          "type": "number"
        },
        "trust_fit": {
          "default": 1.0,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Trust Fit",
          "type": "number"
        },
        "uncertainty_penalty": {
          "default": 0.0,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Uncertainty Penalty",
          "type": "number"
        }
      },
      "required": [
        "total"
      ],
      "title": "CandidateScore",
      "type": "object"
    },
    "CandidateScoreTrace": {
      "additionalProperties": false,
      "properties": {
        "candidate_id": {
          "minLength": 1,
          "title": "Candidate Id",
          "type": "string"
        },
        "hard_filter_decision": {
          "default": "pass",
          "enum": [
            "pass",
            "fail"
          ],
          "title": "Hard Filter Decision",
          "type": "string"
        },
        "hard_filter_results": {
          "additionalProperties": {
            "minLength": 1,
            "type": "string"
          },
          "propertyNames": {
            "minLength": 1
          },
          "title": "Hard Filter Results",
          "type": "object"
        },
        "rank": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Rank"
        },
        "reason_codes": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "title": "Reason Codes",
          "type": "array"
        },
        "schema_version": {
          "const": "p0.v1",
          "default": "p0.v1",
          "title": "Schema Version",
          "type": "string"
        },
        "score": {
          "$ref": "#/$defs/CandidateScore"
        },
        "weighted_components": {
          "additionalProperties": {
            "type": "number"
          },
          "propertyNames": {
            "minLength": 1
          },
          "title": "Weighted Components",
          "type": "object"
        }
      },
      "required": [
        "candidate_id",
        "score"
      ],
      "title": "CandidateScoreTrace",
      "type": "object"
    },
    "RejectedCandidateTrace": {
      "additionalProperties": false,
      "properties": {
        "candidate_id": {
          "minLength": 1,
          "title": "Candidate Id",
          "type": "string"
        },
        "reason_codes": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "title": "Reason Codes",
          "type": "array"
        },
        "schema_version": {
          "const": "p0.v1",
          "default": "p0.v1",
          "title": "Schema Version",
          "type": "string"
        }
      },
      "required": [
        "candidate_id"
      ],
      "title": "RejectedCandidateTrace",
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Deterministic WP-RB3 scoring report for a RoutePlan candidate set.",
  "properties": {
    "baseline_selected_candidate_id": {
      "minLength": 1,
      "title": "Baseline Selected Candidate Id",
      "type": "string"
    },
    "candidate_scores": {
      "items": {
        "$ref": "#/$defs/CandidateScoreTrace"
      },
      "title": "Candidate Scores",
      "type": "array"
    },
    "reason_codes": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "title": "Reason Codes",
      "type": "array"
    },
    "rejected_candidates": {
      "items": {
        "$ref": "#/$defs/RejectedCandidateTrace"
      },
      "title": "Rejected Candidates",
      "type": "array"
    },
    "route_plan_id": {
      "minLength": 1,
      "title": "Route Plan Id",
      "type": "string"
    },
    "route_scoring_id": {
      "minLength": 1,
      "title": "Route Scoring Id",
      "type": "string"
    },
    "routebook_id": {
      "minLength": 1,
      "title": "Routebook Id",
      "type": "string"
    },
    "routebook_version": {
      "minLength": 1,
      "title": "Routebook Version",
      "type": "string"
    },
    "schema_version": {
      "const": "p0.v1",
      "default": "p0.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "score_weights": {
      "additionalProperties": {
        "type": "number"
      },
      "propertyNames": {
        "minLength": 1
      },
      "title": "Score Weights",
      "type": "object"
    },
    "scorer_id": {
      "minLength": 1,
      "title": "Scorer Id",
      "type": "string"
    },
    "scorer_version": {
      "minLength": 1,
      "title": "Scorer Version",
      "type": "string"
    },
    "selected_candidate_id": {
      "minLength": 1,
      "title": "Selected Candidate Id",
      "type": "string"
    },
    "selection_status": {
      "enum": [
        "selected_highest_scoring_candidate",
        "no_passing_candidate_keep_existing_selection"
      ],
      "title": "Selection Status",
      "type": "string"
    },
    "work_unit_id": {
      "minLength": 1,
      "title": "Work Unit Id",
      "type": "string"
    }
  },
  "required": [
    "route_scoring_id",
    "route_plan_id",
    "work_unit_id",
    "routebook_id",
    "routebook_version",
    "scorer_id",
    "scorer_version",
    "baseline_selected_candidate_id",
    "selected_candidate_id",
    "selection_status"
  ],
  "title": "RouteScoringReport",
  "type": "object"
}
